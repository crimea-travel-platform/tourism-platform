# Local development only. Do not reuse these values outside a developer machine.
COMPOSE_PROJECT_NAME=crimea-travel-platform

POSTGRES_IMAGE=postgis/postgis:17-3.5
POSTGRES_DB=tourism
POSTGRES_USER=tourism
POSTGRES_PASSWORD=local-tourism-password
POSTGRES_PORT=5432

REDIS_IMAGE=redis:8.2-alpine
REDIS_PORT=6379

MINIO_IMAGE=minio/minio:RELEASE.2025-07-23T15-54-02Z
MINIO_MC_IMAGE=minio/mc:RELEASE.2025-07-21T05-28-08Z
MINIO_ROOT_USER=tourism-local
MINIO_ROOT_PASSWORD=local-minio-password
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=tourism-media

MAILPIT_IMAGE=axllent/mailpit:v1.27
MAILPIT_SMTP_PORT=1025
MAILPIT_WEB_PORT=8025
